import 'package:flutter/material.dart';
import 'package:video_player/video_player.dart';
import 'package:chewie/chewie.dart';

void main() => runApp(MyApp());

class MyApp extends StatelessWidget {
  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: 'RTSP Player',
      home: MyHomePage(),
    );
  }
}

class _MyHomePageState extends State<MyHomePage> {
  
  VideoPlayerController? _vpc;
  ChewieController? _cc;

  @override
  void initState() {
    super.initState();
    initializePlayer();
  }

  @override
  void dispose() {
    _vpc!.dispose();
    _cc!.dispose();
    super.dispose();
  }

  Future<void> initializePlayer() async {
    _vpc = 
        VideoPlayerController.network('rtsp://admin:123asdfg@185.190.23.227:555/cam/realmonitor?channel=1&subtype=0');

    await Future.wait([_vpc!.initialize()]);
    _cc = ChewieController(
      videoPlayerController: _vpc!,
      autoPlay: true,
      looping: true,
      showOptions: false,
      showControls: true,
      materialProgressColors: ChewieProgressColors(
        playedColor: Colors.blue,
        handleColor: Colors.blue,
        backgroundColor: Colors.grey,
        bufferedColor: Colors.white,
      ),
      allowMuting: true,
      allowFullScreen: true,
      allowedScreenSleep: false,
      allowPlaybackSpeedChanging: true,
      placeholder: Container(color: Colors.black),
      autoInitialize: true,
    );
    setState(() {});
  }
  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: Text('RTSP Player'),
      ),
      body: Center(
        child: _cc != null && _cc!.videoPlayerController.value.isInitialized
            ? Chewie(controller: _cc!)
            : Column(
          mainAxisAlignment: MainAxisAlignment.center,
          children: const [
            CircularProgressIndicator(
              strokeWidth: 2,
              valueColor:
              AlwaysStoppedAnimation<Color>(Colors.greenAccent),
              backgroundColor: Colors.grey,
            ),
            SizedBox(height: 20),
            Text('lblWait'),
          ],
        ),
      ),
    );
  }
}


